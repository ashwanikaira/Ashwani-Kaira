-- Problem: Consecutive Days - Find all the users who were active for 3 consecutive days or more.
--table - sf_events
-- Source StrataScratch (Problem Id 2054)

SELECT DISTINCT user_id
FROM (
    SELECT 
        user_id,
        account_id,
        record_date,
        record_date - INTERVAL '1 day' * 
        ROW_NUMBER() OVER (
            PARTITION BY account_id, user_id 
            ORDER BY record_date
        ) AS grp
    FROM (
        SELECT DISTINCT account_id, user_id, record_date
        FROM sf_event
    ) t1
) t2
GROUP BY user_id, account_id, grp
HAVING COUNT(*) >= 3;
